---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero/Hero.astro';
import ServiceCard from '@/components/ServiceCard/ServiceCard.astro';
import '@/styles/pages/services.scss';
import { seo, servicesPage } from '@/data/strings';
---

<BaseLayout title={seo.pages.services.title} description={seo.pages.services.description}>
  <Hero
    title={servicesPage.hero.title}
    subtitle={servicesPage.hero.subtitle}
    ctaText={servicesPage.hero.ctaText}
    ctaLink={servicesPage.hero.ctaLink}
  />

  <section class="services-list">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow">{servicesPage.list.eyebrow}</p>
        <h2 class="section-title" set:html={servicesPage.list.title} />
        <p class="section-subtitle">{servicesPage.list.subtitle}</p>
      </div>
      <div class="services-list__grid">
        {servicesPage.list.items.map(s => (
          <ServiceCard title={s.title} description={s.description} icon={s.icon} />
        ))}
      </div>
    </div>
  </section>

  <section class="process bg-light">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow">{servicesPage.process.eyebrow}</p>
        <h2 class="section-title" set:html={servicesPage.process.title} />
        <p class="section-subtitle">{servicesPage.process.subtitle}</p>
      </div>
      <div class="process__grid">
        {servicesPage.process.steps.map(p => (
          <div class="process-step">
            <span class="process-step__number">{p.step}</span>
            <h3 class="process-step__title">{p.title}</h3>
            <p class="process-step__text">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="guarantee bg-dark">
    <div class="container guarantee__inner">
      <div class="guarantee__icon" aria-hidden="true">{servicesPage.guarantee.icon}</div>
      <div class="guarantee__content">
        <h2 class="guarantee__title">{servicesPage.guarantee.title}</h2>
        <p class="guarantee__text">{servicesPage.guarantee.text}</p>
      </div>
      <a href={servicesPage.guarantee.ctaHref} class="btn btn--primary guarantee__cta">
        {servicesPage.guarantee.ctaText}
      </a>
    </div>
  </section>
</BaseLayout>
