---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero/Hero.astro';
import ServiceCard from '@/components/ServiceCard/ServiceCard.astro';
import '@/styles/pages/home.scss';
import { company } from '@/data/config';
import { seo, homePage } from '@/data/strings';
---

<BaseLayout title={seo.pages.home.title} description={seo.pages.home.description}>
  <Hero
    title={homePage.hero.title}
    subtitle={homePage.hero.subtitle}
    ctaText={homePage.hero.ctaText}
    ctaLink={homePage.hero.ctaLink}
    secondaryCta={{ text: homePage.hero.secondaryCtaText, href: homePage.hero.secondaryCtaHref }}
    size="large"
  />

  <section class="stats" aria-label="Company statistics">
    <div class="container stats__grid">
      {homePage.stats.map(stat => (
        <div class="stats__item">
          <span class="stats__value">{stat.value}</span>
          <span class="stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="about-intro bg-light">
    <div class="container about-intro__inner">
      <div class="about-intro__text">
        <p class="section-eyebrow">{homePage.aboutIntro.eyebrow}</p>
        <h2 class="section-title" set:html={homePage.aboutIntro.title} />
        {homePage.aboutIntro.body.map(paragraph => (
          <p class="about-intro__body">{paragraph}</p>
        ))}
        <a href={homePage.aboutIntro.ctaHref} class="btn btn--dark">{homePage.aboutIntro.ctaText}</a>
      </div>
      <div class="about-intro__highlights" aria-label="Key strengths">
        {homePage.aboutIntro.highlights.map(h => (
          <div class="about-intro__highlight">
            <span class="about-intro__highlight-icon">{h.icon}</span>
            <div>
              <strong>{h.title}</strong>
              <p>{h.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="benefits">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow">{homePage.benefits.eyebrow}</p>
        <h2 class="section-title" set:html={homePage.benefits.title} />
        <p class="section-subtitle">{homePage.benefits.subtitle}</p>
      </div>
      <div class="benefits__grid">
        {homePage.benefits.items.map(b => (
          <div class="benefit-card">
            <span class="benefit-card__icon" aria-hidden="true">{b.icon}</span>
            <h3 class="benefit-card__title">{b.title}</h3>
            <p class="benefit-card__text">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="services-preview bg-light">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow">{homePage.servicesPreview.eyebrow}</p>
        <h2 class="section-title" set:html={homePage.servicesPreview.title} />
        <p class="section-subtitle">{homePage.servicesPreview.subtitle}</p>
      </div>
      <div class="services-preview__grid">
        {homePage.servicesPreview.items.map(s => (
          <ServiceCard title={s.title} description={s.description} icon={s.icon} />
        ))}
      </div>
      <div class="services-preview__cta">
        <a href={homePage.servicesPreview.ctaHref} class="btn btn--outline-dark">
          {homePage.servicesPreview.ctaText}
        </a>
      </div>
    </div>
  </section>

  <section class="testimonials bg-dark">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow" style="color: #f0a500">{homePage.testimonials.eyebrow}</p>
        <h2 class="section-title" style="color: white" set:html={homePage.testimonials.title} />
      </div>
      <div class="testimonials__grid">
        {homePage.testimonials.items.map(t => (
          <blockquote class="testimonial">
            <div class="testimonial__stars" aria-label="5 stars">★★★★★</div>
            <p class="testimonial__quote">"{t.quote}"</p>
            <footer class="testimonial__footer">
              <strong class="testimonial__author">{t.author}</strong>
              <span class="testimonial__role">{t.role}</span>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container cta-banner__inner">
      <div class="cta-banner__text">
        <h2 class="cta-banner__title">{homePage.ctaBanner.title}</h2>
        <p class="cta-banner__subtitle">{homePage.ctaBanner.subtitle}</p>
      </div>
      <div class="cta-banner__actions">
        <a href={homePage.ctaBanner.primaryCtaHref} class="btn btn--dark">
          {homePage.ctaBanner.primaryCtaText}
        </a>
        <a href={company.phone.href} class="btn btn--outline-dark">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 6.34 6.34l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {homePage.ctaBanner.secondaryCtaText}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
