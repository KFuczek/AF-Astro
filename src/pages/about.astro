---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero/Hero.astro';
import '@/styles/pages/about.scss';
import { company } from '@/data/config';
import { seo, aboutPage } from '@/data/strings';
---

<BaseLayout title={seo.pages.about.title} description={seo.pages.about.description}>
  <Hero
    title={aboutPage.hero.title}
    subtitle={aboutPage.hero.subtitle}
    ctaText={aboutPage.hero.ctaText}
    ctaLink={aboutPage.hero.ctaLink}
  />

  <section class="story bg-light">
    <div class="container story__inner">
      <div class="story__text">
        <p class="section-eyebrow">{aboutPage.story.eyebrow}</p>
        <h2 class="section-title" set:html={aboutPage.story.title} />
        {aboutPage.story.paragraphs.map(p => (
          <p>{p}</p>
        ))}
      </div>

      <div class="story__timeline" aria-label="Company milestones">
        <h3 class="story__timeline-title">{aboutPage.story.milestonesTitle}</h3>
        <ol class="timeline">
          {aboutPage.milestones.map(m => (
            <li class="timeline__item">
              <span class="timeline__year">{m.year}</span>
              <p class="timeline__event">{m.event}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="about-stats">
    <div class="container about-stats__grid">
      {aboutPage.stats.map(stat => (
        <div class="about-stats__item">
          <span class="about-stats__value">{stat.value}</span>
          <span class="about-stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="values bg-light">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow">{aboutPage.values.eyebrow}</p>
        <h2 class="section-title" set:html={aboutPage.values.title} />
        <p class="section-subtitle">{aboutPage.values.subtitle}</p>
      </div>
      <div class="values__grid">
        {aboutPage.values.items.map(v => (
          <div class="value-card">
            <span class="value-card__icon" aria-hidden="true">{v.icon}</span>
            <h3 class="value-card__title">{v.title}</h3>
            <p class="value-card__text">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="team">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow">{aboutPage.team.eyebrow}</p>
        <h2 class="section-title" set:html={aboutPage.team.title} />
        <p class="section-subtitle">{aboutPage.team.subtitle}</p>
      </div>
      <div class="team__grid">
        {aboutPage.team.members.map(member => (
          <div class="team-card">
            <div class="team-card__avatar" aria-hidden="true">
              {member.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div class="team-card__info">
              <strong class="team-card__name">{member.name}</strong>
              <span class="team-card__role">{member.role}</span>
              <span class="team-card__years">{member.years} experience</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="certs bg-dark">
    <div class="container">
      <div class="section-header section-header--centered">
        <p class="section-eyebrow" style="color: #f0a500">{aboutPage.certifications.eyebrow}</p>
        <h2 class="section-title" style="color: white" set:html={aboutPage.certifications.title} />
      </div>
      <ul class="certs__list" role="list">
        {company.certifications.map(cert => (
          <li class="certs__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f0a500" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {cert}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
