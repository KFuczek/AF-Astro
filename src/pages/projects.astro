---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero/Hero.astro';
import ProjectCard from '@/components/ProjectCard/ProjectCard.astro';
import '@/styles/pages/projects.scss';
import { seo, projectsPage } from '@/data/strings';
import { url } from '@/utils/url';
---

<BaseLayout title={seo.pages.projects.title} description={seo.pages.projects.description}>
  <Hero
    title={projectsPage.hero.title}
    subtitle={projectsPage.hero.subtitle}
    ctaText={projectsPage.hero.ctaText}
    ctaLink={projectsPage.hero.ctaLink}
  />

  <section class="projects-section">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow">{projectsPage.portfolio.eyebrow}</p>
        <h2 class="section-title" set:html={projectsPage.portfolio.title} />
        <p class="section-subtitle">{projectsPage.portfolio.subtitle}</p>
      </div>
      <div class="projects-grid">
        {projectsPage.items.map(p => (
          <ProjectCard
            title={p.title}
            description={p.description}
            category={p.category}
            location={p.location}
            year={p.year}
            bgColor={p.bgColor}
            href={`/realizations/${p.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="projects-cta bg-light">
    <div class="container projects-cta__inner">
      <div class="projects-cta__text">
        <h2 class="projects-cta__title">{projectsPage.cta.title}</h2>
        <p class="projects-cta__subtitle">{projectsPage.cta.subtitle}</p>
      </div>
      <div class="projects-cta__actions">
        <a href={url(projectsPage.cta.primaryCtaHref)} class="btn btn--primary">
          {projectsPage.cta.primaryCtaText}
        </a>
        <a href={url(projectsPage.cta.secondaryCtaHref)} class="btn btn--outline-dark">
          {projectsPage.cta.secondaryCtaText}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
