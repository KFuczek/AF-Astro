---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero/Hero.astro';
import '@/styles/pages/contact.scss';
import { company } from '@/data/config';
import { seo, contactPage } from '@/data/strings';

const { details, form } = contactPage;

const contactDetails = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: details.address.title,
    lines: [company.address.line1, company.address.line2],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 6.34 6.34l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    title: details.phone.title,
    lines: [company.phone.display, company.hours.weekdaysShort],
    link: { href: company.phone.href, text: company.phone.display },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    title: details.email.title,
    lines: [company.email.display, company.hours.responseTime],
    link: { href: company.email.href, text: company.email.display },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: details.hours.title,
    lines: [company.hours.weekdays, company.hours.saturday],
  },
];
---

<BaseLayout title={seo.pages.contact.title} description={seo.pages.contact.description}>
  <Hero
    title={contactPage.hero.title}
    subtitle={contactPage.hero.subtitle}
    ctaText={contactPage.hero.ctaText}
    ctaLink={company.phone.href}
  />

  <section class="contact-section">
    <div class="container contact-section__inner">

      <aside class="contact-info" aria-label="Contact information">
        <h2 class="contact-info__title">{contactPage.info.title}</h2>
        <p class="contact-info__intro">{contactPage.info.intro}</p>

        <div class="contact-info__details">
          {contactDetails.map(detail => (
            <div class="contact-detail">
              <div class="contact-detail__icon" aria-hidden="true" set:html={detail.icon} />
              <div class="contact-detail__body">
                <strong class="contact-detail__title">{detail.title}</strong>
                {detail.lines.map((line, i) => (
                  detail.link && i === 0
                    ? <a href={detail.link.href} class="contact-detail__link">{line}</a>
                    : <span class="contact-detail__line">{line}</span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="contact-info__promise">
          <p>
            <strong>{contactPage.info.promiseLabel}</strong> {contactPage.info.promise}
          </p>
        </div>
      </aside>

      <div class="contact-form-wrapper">
        <h2 class="contact-form-wrapper__title">{form.title}</h2>
        <form class="contact-form" id="contact-form" novalidate aria-label={form.ariaLabel}>
          <div class="contact-form__row">
            <div class="form-field">
              <label for="name" class="form-field__label">
                {form.fields.name.label} <span aria-hidden="true">*</span>
              </label>
              <input
                type="text" id="name" name="name" class="form-field__input"
                placeholder={form.fields.name.placeholder}
                required autocomplete={form.fields.name.autocomplete}
              />
              <span class="form-field__error" id="name-error" role="alert"></span>
            </div>
            <div class="form-field">
              <label for="email" class="form-field__label">
                {form.fields.email.label} <span aria-hidden="true">*</span>
              </label>
              <input
                type="email" id="email" name="email" class="form-field__input"
                placeholder={form.fields.email.placeholder}
                required autocomplete={form.fields.email.autocomplete}
              />
              <span class="form-field__error" id="email-error" role="alert"></span>
            </div>
          </div>

          <div class="form-field">
            <label for="phone" class="form-field__label">{form.fields.phone.label}</label>
            <input
              type="tel" id="phone" name="phone" class="form-field__input"
              placeholder={form.fields.phone.placeholder}
              autocomplete={form.fields.phone.autocomplete}
            />
          </div>

          <div class="form-field">
            <label for="service" class="form-field__label">{form.fields.service.label}</label>
            <select id="service" name="service" class="form-field__input form-field__select">
              <option value="">{form.serviceDefaultOption}</option>
              {form.serviceOptions.map(opt => (
                <option>{opt}</option>
              ))}
            </select>
          </div>

          <div class="form-field">
            <label for="message" class="form-field__label">
              {form.fields.message.label} <span aria-hidden="true">*</span>
            </label>
            <textarea
              id="message" name="message" class="form-field__input form-field__textarea"
              placeholder={form.fields.message.placeholder}
              rows="6" required
            ></textarea>
            <span class="form-field__error" id="message-error" role="alert"></span>
          </div>

          <div class="form-field form-field--checkbox">
            <label class="form-field__checkbox-label">
              <input type="checkbox" name="consent" required />
              <span>{form.fields.consent.label} <span aria-hidden="true">*</span></span>
            </label>
          </div>

          <button type="submit" class="btn btn--primary contact-form__submit">
            {form.submitText}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>

          <div class="contact-form__success" id="form-success" aria-live="polite" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <p><strong>{form.success.title}</strong> {form.success.text}</p>
          </div>
        </form>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  import { contactPage } from '@/data/strings';

  const form       = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  function showError(inputId: string, message: string) {
    const errorEl = document.getElementById(`${inputId}-error`);
    const inputEl = document.getElementById(inputId);
    if (errorEl) errorEl.textContent = message;
    inputEl?.classList.add('form-field__input--error');
  }

  function clearError(inputId: string) {
    const errorEl = document.getElementById(`${inputId}-error`);
    const inputEl = document.getElementById(inputId);
    if (errorEl) errorEl.textContent = '';
    inputEl?.classList.remove('form-field__input--error');
  }

  ['name', 'email', 'message'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', () => clearError(id));
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    let valid = true;

    const name    = (document.getElementById('name')    as HTMLInputElement)?.value.trim();
    const email   = (document.getElementById('email')   as HTMLInputElement)?.value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement)?.value.trim();

    if (!name) {
      showError('name', contactPage.form.errors.name);
      valid = false;
    } else {
      clearError('name');
    }

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('email', contactPage.form.errors.email);
      valid = false;
    } else {
      clearError('email');
    }

    if (!message || message.length < 10) {
      showError('message', contactPage.form.errors.message);
      valid = false;
    } else {
      clearError('message');
    }

    if (valid) {
      form.style.display = 'none';
      if (successMsg) successMsg.hidden = false;
    }
  });
</script>
