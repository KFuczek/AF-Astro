---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/pages/realization.scss';
import { company } from '@/data/config';
import { projectsPage } from '@/data/strings';

export function getStaticPaths() {
  return projectsPage.items.map(project => ({
    params: { slug: project.slug },
    props:  { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={project.title}
  description={project.description}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container breadcrumb__inner">
      <a href="/" class="breadcrumb__link">Home</a>
      <span class="breadcrumb__sep" aria-hidden="true">›</span>
      <a href="/projects" class="breadcrumb__link">Projects</a>
      <span class="breadcrumb__sep" aria-hidden="true">›</span>
      <span class="breadcrumb__current" aria-current="page">{project.title}</span>
    </div>
  </nav>

  <!-- Visual hero -->
  <div class="project-hero">
    <div class="project-hero__bg" style={`background-color: ${project.bgColor}`}></div>
    <div class="project-hero__overlay container">
      <span class="project-hero__category">{project.category}</span>
      <h1 class="project-hero__title">{project.title}</h1>
      <div class="project-hero__meta">
        <span class="project-hero__meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {project.location}
        </span>
        <span class="project-hero__meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Completed {project.year}
        </span>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <section class="project-content">
    <div class="container project-content__inner">

      <!-- Description -->
      <div class="project-description">
        <div class="project-description__body">
          {project.fullDescription.map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <!-- Highlights sidebar -->
      <aside class="project-highlights" aria-label="Project highlights">
        <h2 class="project-highlights__title">Project Details</h2>
        <ul class="project-highlights__list" role="list">
          {project.highlights.map(h => (
            <li class="project-highlights__item">
              <span class="project-highlights__label">{h.label}</span>
              <span class="project-highlights__value">{h.value}</span>
            </li>
          ))}
        </ul>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="project-cta">
    <div class="container project-cta__inner">
      <div class="project-cta__text">
        <h2 class="project-cta__title">Interested in a Similar Project?</h2>
        <p>Tell us about your requirements — we'll respond with a free, no-obligation quote within 48 hours.</p>
      </div>
      <div class="project-cta__actions">
        <a href="/contact" class="btn btn--primary">Get a Free Quote</a>
        <a href="/projects" class="btn btn--outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          All Projects
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
