---
interface Props {
  title: string;
  description: string;
  category: string;
  location: string;
  year: string | number;
  bgColor?: string;
}

const {
  title,
  description,
  category,
  location,
  year,
  bgColor = '#2a2a2a',
} = Astro.props;
---

<article class="project-card">
  <div class="project-card__visual" style={`background-color: ${bgColor}`} aria-hidden="true">
    <div class="project-card__visual-inner"></div>
    <span class="project-card__category">{category}</span>
  </div>
  <div class="project-card__body">
    <div class="project-card__meta">
      <span class="project-card__location">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {location}
      </span>
      <span class="project-card__year">{year}</span>
    </div>
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__description">{description}</p>
  </div>
</article>

<style lang="scss">
  @use '../styles/variables' as *;

  .project-card {
    border-radius: $radius-md;
    overflow: hidden;
    background-color: $color-white;
    border: 1px solid $color-gray-light;
    transition: transform $transition-slow, box-shadow $transition-slow;

    &:hover {
      transform: translateY(-5px);
      box-shadow: $shadow-lg;

      .project-card__visual-inner {
        opacity: 1;
        transform: scale(1.05);
      }
    }

    // ── Visual placeholder ──────────────────────────────────────────────────
    &__visual {
      position: relative;
      height: 210px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      padding: $spacing-sm;
    }

    &__visual-inner {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom right,
        rgba($color-white, 0.05) 0%,
        rgba($color-white, 0) 60%
      );
      opacity: 0.5;
      transition: opacity $transition-slow, transform $transition-slow;

      &::before {
        content: '🏗';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -55%);
        font-size: 3.5rem;
        opacity: 0.2;
      }
    }

    &__category {
      position: relative;
      z-index: 1;
      background-color: $color-accent;
      color: $color-dark;
      font-size: $font-size-xs;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.3rem 0.65rem;
      border-radius: $radius-sm;
    }

    // ── Body ────────────────────────────────────────────────────────────────
    &__body {
      padding: $spacing-md;
    }

    &__meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: $spacing-xs;
    }

    &__location {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: $font-size-xs;
      color: $color-gray;

      svg { color: $color-accent; }
    }

    &__year {
      font-size: $font-size-xs;
      font-weight: 600;
      color: $color-gray;
    }

    &__title {
      font-size: $font-size-lg;
      color: $color-dark;
      margin-bottom: $spacing-xs;
      line-height: 1.3;
    }

    &__description {
      color: $color-gray;
      font-size: $font-size-sm;
      line-height: 1.65;
    }
  }
</style>
