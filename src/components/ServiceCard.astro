---
interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

const { title, description, icon, href = '/contact' } = Astro.props;
---

<article class="service-card">
  <div class="service-card__icon" aria-hidden="true">{icon}</div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__description">{description}</p>
  <a href={href} class="service-card__cta">
    Request this service
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
</article>

<style lang="scss">
  @use '../styles/variables' as *;

  .service-card {
    background-color: $color-white;
    border: 1px solid $color-gray-light;
    border-top: 3px solid transparent;
    border-radius: $radius-md;
    padding: $spacing-lg;
    display: flex;
    flex-direction: column;
    transition: transform $transition-slow, box-shadow $transition-slow, border-top-color $transition-slow;

    &:hover {
      transform: translateY(-5px);
      box-shadow: $shadow-lg;
      border-top-color: $color-accent;
    }

    &__icon {
      font-size: 2.4rem;
      margin-bottom: $spacing-sm;
      line-height: 1;
    }

    &__title {
      font-size: $font-size-xl;
      color: $color-dark;
      margin-bottom: $spacing-xs;
    }

    &__description {
      color: $color-gray;
      font-size: $font-size-sm;
      line-height: 1.75;
      flex: 1;
      margin-bottom: $spacing-md;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: $color-accent;
      font-weight: 600;
      font-size: $font-size-sm;
      transition: gap $transition-base, color $transition-base;
      margin-top: auto;

      &:hover,
      &:focus-visible {
        color: $color-accent-dark;
        gap: 0.65rem;
        outline: none;
      }

      svg {
        transition: transform $transition-base;
      }

      &:hover svg {
        transform: translateX(3px);
      }
    }
  }
</style>
