---
interface Props {
  title: string;
  description: string;
  category: string;
  location: string;
  year: string | number;
  bgColor?: string;
}

const {
  title,
  description,
  category,
  location,
  year,
  bgColor = '#2a2a2a',
} = Astro.props;
---

<article class="project-card">
  <div class="project-card__visual" style={`background-color: ${bgColor}`} aria-hidden="true">
    <div class="project-card__visual-inner"></div>
    <span class="project-card__category">{category}</span>
  </div>
  <div class="project-card__body">
    <div class="project-card__meta">
      <span class="project-card__location">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {location}
      </span>
      <span class="project-card__year">{year}</span>
    </div>
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__description">{description}</p>
  </div>
</article>

<style lang="scss">
  @use './ProjectCard.scss';
</style>
