---
import { company } from '@/data/config';
import { footer } from '@/data/strings';

const year = new Date().getFullYear();
---

<footer class="footer" aria-label={footer.ariaLabel}>
  <div class="footer__main">
    <div class="container footer__grid">

      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={`${company.name} home`}>
          <span class="footer__logo-badge">{company.logoBadge}</span>
          <span class="footer__logo-name">{company.name}</span>
        </a>
        <p class="footer__tagline">{footer.tagline}</p>
        <div class="footer__cert">
          {footer.certBadges.map(badge => (
            <span class="footer__cert-badge">{badge}</span>
          ))}
        </div>
      </div>

      <!-- Quick links -->
      <div class="footer__col">
        <h3 class="footer__heading">{footer.quickLinksHeading}</h3>
        <ul class="footer__list" role="list">
          {footer.links.map(link => (
            <li><a href={link.href} class="footer__link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="footer__col">
        <h3 class="footer__heading">{footer.servicesHeading}</h3>
        <ul class="footer__list" role="list">
          {footer.serviceLinks.map(s => (
            <li><a href="/services" class="footer__link">{s}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer__col">
        <h3 class="footer__heading">{footer.contactHeading}</h3>
        <ul class="footer__contact-list" role="list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{company.address.line1},<br />{company.address.line2}</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 6.34 6.34l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href={company.phone.href}>{company.phone.display}</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href={company.email.href}>{company.email.display}</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{company.hours.weekdaysShort}</span>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {year} {company.legalName}. {footer.copyrightSuffix}</p>
      <p>{footer.builtWith} <a href="https://astro.build" target="_blank" rel="noopener" class="footer__astro-link">Astro</a></p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use './Footer.scss';
</style>
